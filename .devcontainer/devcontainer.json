{
  "name": "ZoneBac Plugin Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "wordpress",
  "workspaceFolder": "/var/www/html/wp-content/plugins/zonebac",
  "postStartCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [80],
  "portsAttributes": {
    "80": {
      "label": "ZoneBac Site",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "xdebug.php-debug",
        "bmewburn.vscode-intelephense-client"
      ]
    }
  }
}
