{
  "name": "ZoneBac Plugin Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "wordpress",
  "workspaceFolder": "/var/www/html/wp-content/plugins/zonebac",
  "postStartCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "WordPress Site",
      "onAutoForward": "openBrowser"
    }
  }
}
